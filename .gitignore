# ============================================================================
#  C_HUD_Runway  —  MSFS WASM gauge project  ·  .gitignore
#  v2.7.0  —  Phase 2 consolidated ignore patterns
# ============================================================================

# ---------------------------------------------------------------------------
#  Build output (WASM binaries, CMake artefacts, object files)
# ---------------------------------------------------------------------------
build/
*.wasm
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exp
*.ilk
*.pdb

# ---------------------------------------------------------------------------
#  IDE / Editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ---------------------------------------------------------------------------
#  OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
#  Python cache & test artifacts
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build-py/
*.egg

# ---------------------------------------------------------------------------
#  External libraries (clone into lib/ at setup time)
# ---------------------------------------------------------------------------
lib/nanovg/

# ---------------------------------------------------------------------------
#  MSFS community-package archives (generated)
# ---------------------------------------------------------------------------
*.zip
*.tar.gz
*.7z
*.rar

# ---------------------------------------------------------------------------
#  Installer generated files — runtime/manifest, logs, backups, telemetry
# ---------------------------------------------------------------------------
installer/backups/
installer/installer.log
installer/*.log

# ---------------------------------------------------------------------------
#  Editor swap files
# ---------------------------------------------------------------------------
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
#  Backup / temporary leftovers
# ---------------------------------------------------------------------------
*.bak
*.orig
*.tmp
*.temp
*.log

# ---------------------------------------------------------------------------
#  C/C++ compile artifacts (non-WASM)
# ---------------------------------------------------------------------------
*.gcno
*.gcda
*.gcov
*.profraw
